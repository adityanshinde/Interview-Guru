{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node server.ts",
    "build:ui": "vite build",
    "build:server": "tsup server.ts --format cjs --out-dir .",
    "build": "npm-run-all build:ui build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist release server.cjs",
    "lint": "tsc --noEmit",
    "electron:dev": "node electron-dev.cjs",
    "predist": "taskkill /F /IM InterviewGuru.exe 2>nul || exit 0",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.interviewguru.app",
    "productName": "InterviewGuru",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icons/win/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InterviewGuru"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "adityanshinde",
        "repo": "Parakeet-AI-Clone"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.cjs",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "@clerk/themes": "^2.4.57",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.6.22",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-icon-maker": "^0.0.5",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
