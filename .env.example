# InterviewGuru environment template.
#
# Use this file for local development.
# For Vercel, copy the same values into the project Environment Variables panel.

# Frontend auth
VITE_CLERK_PUBLISHABLE_KEY="pk_live_your_production_key"

# Backend persistence
DATABASE_URL="postgresql://your_user:your_password@your-neon-host.neon.tech/your_db?sslmode=require&channel_binding=require"

# AI services
GROQ_API_KEY="gsk_your_groq_key"
GEMINI_API_KEY="AIza_your_gemini_key"

# Trial anti-abuse protection
TRIAL_SECURITY_SALT="replace_with_a_long_random_secret"

# Optional same-origin override.
# Leave empty for Vercel/custom-domain deployments so the app uses /api on the same host.
VITE_API_URL=""

# Optional canonical app URL for redirects and hosted environments.
# Set this to your custom domain on Vercel if you want a stable public URL reference.
APP_URL="https://your-custom-domain.com"
